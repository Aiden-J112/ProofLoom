{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofloom.local/schemas/review-event.schema.json",
  "title": "Review Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "sequence", "assertion_id", "action", "reviewer", "reviewed_at", "replacement_assertion_id", "replacement_assertion", "note", "schema_version"],
  "properties": {
    "id": {"type": "string", "pattern": "^rev_[0-9a-f]{32}$"},
    "sequence": {"type": "integer", "minimum": 1},
    "assertion_id": {"type": "string", "minLength": 1},
    "action": {"enum": ["accept", "reject", "replace", "needs_domain_review"]},
    "reviewer": {"const": "local-user"},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "replacement_assertion_id": {"type": ["string", "null"]},
    "replacement_assertion": {"oneOf": [{"$ref": "#/$defs/replacementAssertion"}, {"type": "null"}]},
    "note": {"type": ["string", "null"]},
    "schema_version": {"const": "1"}
  },
  "allOf": [{
    "if": {"properties": {"action": {"const": "replace"}}, "required": ["action"]},
    "then": {
      "properties": {
        "replacement_assertion_id": {"type": "string", "minLength": 1},
        "replacement_assertion": {"$ref": "#/$defs/replacementAssertion"}
      }
    },
    "else": {
      "properties": {
        "replacement_assertion_id": {"type": "null"},
        "replacement_assertion": {"type": "null"}
      }
    }
  }],
  "$defs": {
    "replacementAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "subject_id", "predicate", "object_id", "primary_evidence_id", "supporting_evidence_ids", "status", "extraction", "replaces_assertion_id"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "subject_id": {"type": "string", "minLength": 1},
        "predicate": {"enum": ["COMPOSED_OF", "PROMPTS", "CALLS_TOOL", "PRODUCES", "VERIFIES", "BLOCKS"]},
        "object_id": {"type": "string", "minLength": 1},
        "primary_evidence_id": {"type": "string", "minLength": 1},
        "supporting_evidence_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "status": {"const": "candidate"},
        "replaces_assertion_id": {"type": "string", "minLength": 1},
        "extraction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "model", "prompt_version", "schema_version", "generated_at", "mode"],
          "properties": {
            "provider": {"type": "string", "minLength": 1},
            "model": {"type": "string", "minLength": 1},
            "prompt_version": {"type": "string", "minLength": 1},
            "schema_version": {"const": "1"},
            "generated_at": {"type": "string", "format": "date-time"},
            "mode": {"enum": ["fixture", "api"]}
          }
        }
      }
    }
  }
}
